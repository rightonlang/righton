import std

fn main():
    // String contains
    let greeting = "Hello, World!"
    print("contains World:")
    print_int(contains(greeting, "World"))
    print("contains Rust:")
    print_int(contains(greeting, "Rust"))

    // String starts_with / ends_with
    print("starts_with Hello:")
    print_int(starts_with(greeting, "Hello"))
    print("starts_with World:")
    print_int(starts_with(greeting, "World"))
    print("ends_with World!:")
    print_int(ends_with(greeting, "World!"))
    print("ends_with Hello:")
    print_int(ends_with(greeting, "Hello"))

    // String substr
    print("substr 7 5:")
    let part = substr(greeting, 7, 5)
    print(part)

    // String trim
    let padded = "  hello world  "
    print("trimmed:")
    print(trim(padded))

    // String case conversion
    print("uppercase:")
    print(to_uppercase(greeting))
    print("lowercase:")
    print(to_lowercase(greeting))

    // Parsing
    let num_str = "42"
    print("to_int 42:")
    print_int(to_int(num_str))
    print("to_float 3.14:")
    print_float(to_float("3.14"))

    // Math functions
    print("abs -5:")
    print_int(abs(-5))
    print("floor 3.7:")
    print_float(floor(3.7))
    print("ceil 3.2:")
    print_float(ceil(3.2))
    print("round 3.5:")
    print_float(round(3.5))
    print("min 10 20:")
    print_int(min(10, 20))
    print("max 10 20:")
    print_int(max(10, 20))
    print("pow 2 10:")
    print_int(pow(2, 10))

    // to_string with different types
    let s_int = to_string(123)
    print("to_string int:")
    print(s_int)
    let s_float = to_string(4.56)
    print("to_string float:")
    print(s_float)
    let s_str = to_string("direct")
    print("to_string string:")
    print(s_str)

    // is_empty
    let empty = ""
    print("is_empty empty:")
    print_int(is_empty(empty))
    print("is_empty literal:")
    print_int(is_empty(""))
    print("is_empty hello:")
    print_int(is_empty("hello"))

    // len
    print("len greeting:")
    print_int(len(greeting))

    // escape sequences
    print("newline:")
    print("line1\nline2")
    print("tab:")
    print("col1\tcol2")
    print("backslash:")
    print("path\\to\\file")
    print("quote:")
    print("she said \"hello\"")

    // exit (last test since it exits)
    print("All tests passed!")
    // Do not exit so we can see output
